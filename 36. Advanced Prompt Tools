<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Advanced Prompt Tools</title>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', system-ui, sans-serif;
  background: #e8e8f8;
  min-height: 100vh;
  padding: 40px 20px 60px;
  color: #2d2d5e;
}

/* Header */
.header {
  text-align: center;
  margin-bottom: 30px;
}

.badge {
  display: inline-block;
  background: #7c3aed;
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 6px 18px;
  border-radius: 999px;
  letter-spacing: 1.5px;
  margin-bottom: 12px;
}

.header h1 {
  font-size: 36px;
  color: #5b21b6;
  font-weight: 800;
}

.header p {
  font-size: 14px;
  color: #6b7280;
}

/* Info bar */
.info {
  margin-top: 10px;
  font-size: 13px;
  color: #4b5563;
}

/* Cards */
.card {
  background: white;
  border: 1.5px solid #e0dff5;
  border-radius: 16px;
  padding: 24px;
  max-width: 900px;
  margin: 0 auto 20px;
}

.section-label {
  font-size: 11px;
  font-weight: 700;
  color: #7c3aed;
  letter-spacing: 1.4px;
  margin-bottom: 10px;
  text-transform: uppercase;
}

/* Inputs */
textarea, select {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 1.5px solid #ddd8f5;
  font-size: 14px;
  font-family: monospace;
  background: #fafafa;
}

/* Row */
.row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* Buttons */
button {
  border: none;
  padding: 12px 20px;
  border-radius: 10px;
  cursor: pointer;
  font-weight: 600;
}

.btn-primary {
  background: #5b21b6;
  color: white;
}

.btn-secondary {
  background: transparent;
  border: 1.5px solid #c4b5fd;
  color: #5b21b6;
}

/* Output */
.output {
  background: #fff;
  border: 1.5px solid #e0dff5;
  border-radius: 16px;
  padding: 18px;
  min-height: 160px;
  white-space: pre-wrap;
}

.step {
  background: #f5f3ff;
  border-left: 4px solid #7c3aed;
  padding: 10px;
  margin-bottom: 8px;
  border-radius: 8px;
}

.final {
  margin-top: 12px;
  padding: 12px;
  background: #ede9fe;
  font-weight: 700;
  border-radius: 10px;
}

/* History */
.history-item {
  background: #f5f3ff;
  padding: 10px;
  border-radius: 10px;
  margin-bottom: 8px;
  cursor: pointer;
  font-size: 13px;
}
</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
  <div class="badge">⚡ Advanced Prompt Tools</div>
  <h1>Prompt Engineering Lab</h1>

  <div class="info">
    👩‍🎓 Student: <b>Hamna Munir</b> | 👨‍🏫 Teacher: <b>Sir Nadeem</b>
  </div>
</div>

<!-- SYSTEM -->
<div class="card">
  <div class="section-label">System Prompt</div>
  <textarea id="system" rows="3"
  placeholder="Define AI behavior..."></textarea>
</div>

<!-- SETTINGS -->
<div class="card">
  <div class="section-label">Prompt Settings</div>

  <div class="row">
    <select id="tone">
      <option>Formal</option>
      <option>Creative</option>
      <option>Simple</option>
      <option>Debug Mode</option>
    </select>

    <select id="mode">
      <option>Explain</option>
      <option>Step-by-Step</option>
      <option>Short Answer</option>
    </select>
  </div>
</div>

<!-- USER -->
<div class="card">
  <div class="section-label">User Prompt</div>
  <textarea id="user" rows="3"
  placeholder="Enter your question..."></textarea>

  <br><br>
  <button class="btn-primary" onclick="generate()">Run Prompt</button>
  <button class="btn-secondary" onclick="clearAll()">Clear</button>
</div>

<!-- OUTPUT -->
<div class="card">
  <div class="section-label">AI Output</div>
  <div class="output" id="output">Response will appear here...</div>
</div>

<!-- HISTORY -->
<div class="card">
  <div class="section-label">History</div>
  <div id="history"></div>
</div>

<script>
let history = [];

async function generate() {
  const system = document.getElementById("system").value;
  const user = document.getElementById("user").value;
  const tone = document.getElementById("tone").value;
  const mode = document.getElementById("mode").value;

  if (!user) return alert("Enter a prompt!");

  document.getElementById("output").innerText = "Generating...";

  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 700,
      system: system || "You are an advanced prompt engine.",
      messages: [{
        role: "user",
        content:
`Tone: ${tone}
Mode: ${mode}

Question:
${user}`
      }]
    })
  });

  const data = await res.json();
  const text = data.content?.[0]?.text || "Error";

  render(text);
  save(user, text);
}

function render(text) {
  let lines = text.split("\n");
  let html = "";
  let final = "";

  lines.forEach(l => {
    if (l.toLowerCase().includes("final")) {
      final = l;
    } else if (l.trim()) {
      html += `<div class="step">${l}</div>`;
    }
  });

  document.getElementById("output").innerHTML =
    html + `<div class="final">${final}</div>`;
}

function save(prompt, response) {
  history.unshift({ prompt, response });
  if (history.length > 10) history.pop();

  const box = document.getElementById("history");
  box.innerHTML = "";

  history.forEach(h => {
    const div = document.createElement("div");
    div.className = "history-item";
    div.innerText = "🧠 " + h.prompt;
    div.onclick = () => render(h.response);
    box.appendChild(div);
  });
}

function clearAll() {
  document.getElementById("user").value = "";
  document.getElementById("output").innerText = "";
}
</script>

</body>
</html>
